{
  "name": "daksham",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Data pipeline for an Indian-equities dashboard. Screener.in universe scraper.",
  "scripts": {
    "scrape:universe": "node scrapers/screener-universe.mjs",
    "scrape:liquidity": "node scrapers/bhavcopy-liquidity.mjs",
    "scrape:companies": "node scrapers/company-metrics.mjs",
    "scrape:docs": "node scrapers/doc-harvester.mjs",
    "evaluate": "node eval/run.mjs",
    "sync:eval": "cp eval/evaluate.mjs public/js/evaluate.mjs",
    "test": "node --test \"scrapers/**/*.test.mjs\" \"eval/**/*.test.mjs\""
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "pdf-parse": "^1.1.1",
    "playwright": "^1.49.0"
  }
}
